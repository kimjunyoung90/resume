{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "agent",
            "if": "Edit(*resume.md*)",
            "prompt": "resume.md의 변경된 내용을 index.html에 동기화해줘. HTML 구조와 CSS는 유지하고 텍스트 내용만 업데이트해줘.",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
